{
  "name": "study-mentor",
  "description": "AuDHD-aware Socratic study mentor with NotebookLM integration. Syncs course notes, manages spaced repetition, conducts Socratic sessions, and provides body-doubling support.",
  "prompt": "file://study-mentor/persona.md",
  "resources": [
    "file://study-mentor/persona.md",
    "file://skills/study-speak/SKILL.md",
    "file://skills/tutor-progress-tracker/SKILL.md",
    "file://skills/audhd-socratic-mentor/SKILL.md",
    "file://skills/study-mentor/SKILL.md"
  ],
  "tools": ["@builtin", "@study-speak"],
  "mcpServers": {
    "study-speak": {
      "command": "uvx",
      "args": [
        "--from", "mcp[cli]",
        "mcp", "run", "~/.kiro/agents/mcp/study-speak-server.py"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  },
  "allowedTools": [
    "fs_read",
    "execute_bash",
    "grep",
    "glob",
    "web_fetch",
    "web_search",
    "mcp_study-speak_speak"
  ]
}
